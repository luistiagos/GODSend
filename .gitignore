# Compiled binaries
*.exe
*.dll
.DS_Store

# Go build output (default layout: binary next to electron-app under src/)
src/godsend_*
src/godsend.exe

# Build artifacts
dist/

# Local tools (external binaries, not tracked)
tools/

# Pacote BadAvatar incorporado (~726 MB de binarios de terceiros).
# Catalogado por SHA-256 em assets/badavatar-*.json (esses ficam versionados).
# Reimportavel com `npm run payload:update`; nao versionar a arvore binaria.
src/electron-app/assets/badavatar-1.1/

# Electron / Node
node_modules/
src/electron-app/node_modules/
src/electron-app/dist/

# Electron TypeScript artefacts (compiled in-place; source is the .ts files)
src/electron-app/app/*.js
src/electron-app/infrastructure/*.js
src/electron-app/ipc/*.js
src/electron-app/services/*.js
src/electron-app/renderer/**/*.js
src/electron-app/*.js

# Playwright test results (auto-generated videos/screenshots)
src/electron-app/test-results/

# Runtime data dirs (created by the backend at runtime)
Ready/
Temp/
Transfer/

# Electron builder temp artefacts
src/electron-app/.webpack/
src/electron-app/out/

.claude/settings.local.json

# graphify knowledge graph outputs (generated, not tracked)
graphify-out/
.gitlab-token
.gofile-io-token
r2-config.json
.env
build.properties
